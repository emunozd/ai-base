# ─────────────────────────────────────────────────────────────────────────────
# Kingsrow AI — Variables de entorno
# Copiar a .env y ajustar valores según el entorno.
# Ninguna variable es obligatoria — todos tienen default razonable.
# ─────────────────────────────────────────────────────────────────────────────

# ── Modelo MLX ───────────────────────────────────────────────────────────────
# Path en HuggingFace Hub o ruta local al modelo
KR_MODEL_PATH=mlx-community/Qwen3.5-35B-A3B-4bit

# ── Servidor ─────────────────────────────────────────────────────────────────
# Dirección de bind — usar 0.0.0.0 en macOS, no la IP específica
KR_HOST=0.0.0.0
KR_PORT=8181

# ── Autenticación ────────────────────────────────────────────────────────────
# Clave requerida en header X-API-Key para todos los endpoints (excepto /health y /v1/models)
# Dejar vacío para deshabilitar autenticación
KR_API_KEY=

# ── Límites de tokens de salida ───────────────────────────────────────────────
# /v1/messages (Anthropic / Claude Code)
KR_MAX_TOKENS_CHAT=8192
# /v1/chat/completions (OpenAI / AnythingLLM)
KR_MAX_TOKENS_OPENAI=4096
# Routers de proyecto (LUKA, etc.)
KR_MAX_TOKENS_LUKA=600

# ── Contexto de entrada ───────────────────────────────────────────────────────
# Máximo de tokens de entrada antes de truncar historial (aprox. 1 token = 4 chars)
# Qwen3.5-35B-A3B-4bit se degrada por encima de ~20k tokens de entrada
KR_MAX_CTX_TOKENS=20000
# Número de mensajes recientes a preservar siempre al truncar historial
KR_CTX_COLA_MSGS=6

# ── Búsqueda web (DuckDuckGo) ─────────────────────────────────────────────────
# Número máximo de resultados que devuelve ddgs por query
KR_WEB_SEARCH_MAX_RESULTS=5
# Máximo de caracteres de texto extraído por URL en fetch
KR_WEB_FETCH_MAX_CHARS=3000

# ── Procesamiento de imágenes ─────────────────────────────────────────────────
# Resolución máxima (px) al redimensionar imágenes antes de inferencia
KR_IMG_MAX=1024

# KALO - Analisis plato
KALO_FACTOR_FOTO_PLATO=1.40